# SPADE environment variables.
# Copy to `.env` (git-ignored) and fill in. Loaded automatically at script
# entrypoints via spade.utils.load_env(). Existing shell exports take precedence
# over values here (override=False), so CI secrets are never clobbered.

# --- Weights & Biases ---------------------------------------------------------
# API key for logging runs. Get it from https://wandb.ai/authorize.
# Alternatively run `wandb login` once (writes ~/.netrc) and leave this blank.
WANDB_API_KEY=
# Optional: team/user the runs belong to. Leave blank to use your default entity.
WANDB_ENTITY=
# online | offline | disabled. Mirrors --wandb-mode; the CLI flag wins if passed.
WANDB_MODE=online
WANDB_PROJECT=spade

# --- JAX / CUDA runtime -------------------------------------------------------
# Which GPU(s) JAX may use, e.g. "0" or "0,1". Unset to use all visible devices.
CUDA_VISIBLE_DEVICES=0
# Fraction of GPU memory JAX preallocates (0.0-1.0). Lower it to share a GPU.
XLA_PYTHON_CLIENT_MEM_FRACTION=0.9
